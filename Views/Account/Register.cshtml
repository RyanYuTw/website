@model MyWeb.Models.RegisterViewModel
@{
    ViewBag.Title = "會員註冊";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>會員註冊</h2>
        <hr />

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Account, "帳號", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Account, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Account, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Name, "姓名", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Email, "Email", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Mobile, "手機", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Mobile, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Mobile, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Password, "密碼", new { @class = "form-label" })
                @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.ConfirmPassword, "確認密碼", new { @class = "form-label" })
                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
            </div>
            <button type="submit" class="btn btn-dark w-100">註冊</button>
        }

        <div class="mt-3 text-center">
            已有帳號？<a href="@Url.Action("Login")">立即登入</a>
        </div>
    </div>
</div>
