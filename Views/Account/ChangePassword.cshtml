@model MyWeb.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "修改密碼";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2>修改密碼</h2>
        <hr />

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-success">@ViewBag.Message</div>
        }

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.OldPassword, "舊密碼", new { @class = "form-label" })
                @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.NewPassword, "新密碼", new { @class = "form-label" })
                @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.ConfirmPassword, "確認新密碼", new { @class = "form-label" })
                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
            </div>
            <button type="submit" class="btn btn-dark">更新密碼</button>
        }
    </div>
</div>
