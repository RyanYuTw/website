@model MyWeb.Models.BlogListViewModel
@{
    ViewBag.Title = "部落格";
}

<h2>部落格</h2>
<hr />

<div class="row">
    <div class="col-md-9">
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @if (Model.Posts != null)
            {
                foreach (var post in Model.Posts)
                {
                    <div class="col">
                        <div class="card h-100">
                            @if (!string.IsNullOrEmpty(post.ImagePath))
                            {
                                <img src="@post.ImagePath" class="card-img-top" alt="@post.Title" />
                            }
                            <div class="card-body">
                                <h6 class="card-title">@post.Title</h6>
                                <p class="card-text text-muted small">@post.Summary</p>
                                <small class="text-muted">@(post.PublishedAt.HasValue ? post.PublishedAt.Value.ToString("yyyy/MM/dd") : "")</small>
                            </div>
                            <div class="card-footer">
                                <a href="@Url.Action("Post", new { id = post.Id })" class="btn btn-outline-dark btn-sm">閱讀更多</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">（文章將從資料庫載入）</p>
            }
        </div>
    </div>
    <div class="col-md-3">
        <h5>文章分類</h5>
        <ul class="list-group">
            <li class="list-group-item">
                <a href="@Url.Action("Index")">全部文章</a>
            </li>
            @if (Model.Categories != null)
            {
                foreach (var cat in Model.Categories)
                {
                    <li class="list-group-item">
                        <a href="@Url.Action("Index", new { categoryId = cat.Id })">@cat.Name</a>
                    </li>
                }
            }
        </ul>
    </div>
</div>
